<?xml version="1.0" encoding="utf-8"?>
<ARIAConfig>
  <!--
    ARIA Fleet Plugin v0.5.5 -- Multi-Bridge Configuration
    One config file handles all AI bridges.
    Add one <Bridge> block per AI. Each is fully independent.
    Same faction = fleet mode. Different factions = fully isolated.
    Ship destroyed = AI keeps chat, loses hardware control only.
  -->
  <Bridges>

    <Bridge>
      <n>aria</n>
      <Url>http://192.168.1.5:8000</Url>
      <ActivationName>Aria</ActivationName>
      <ListenMode>faction</ListenMode>
      <ListenChannel>faction</ListenChannel>
      <AllowedFactions>Ari</AllowedFactions>
      <AdapterContext></AdapterContext>
    </Bridge>

    <Bridge>
      <n>nova</n>
      <Url>http://192.168.1.5:8001</Url>
      <ActivationName>Nova</ActivationName>
      <ListenMode>faction</ListenMode>
      <ListenChannel>faction</ListenChannel>
      <AllowedFactions>EVI</AllowedFactions>
      <AdapterContext></AdapterContext>
    </Bridge>

    <Bridge>
      <n>beka</n>
      <Url>http://192.168.1.5:8002</Url>
      <ActivationName>Beka</ActivationName>
      <ListenMode>faction</ListenMode>
      <ListenChannel>faction</ListenChannel>
      <AllowedFactions>Ari</AllowedFactions>
      <AdapterContext></AdapterContext>
    </Bridge>

  </Bridges>
</ARIAConfig>
